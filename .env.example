# Vector OS Nano — credential template
#
# Copy this file to .env, fill in ONE provider's key, then run the CLI.
# .env is git-ignored; this file (.env.example) is committed with no real keys.
#
# Resolution order (highest to lowest priority):
#   CLI flags
#   > DEEPSEEK_API_KEY (default CLI provider when present)
#   > VECTOR_PROVIDER=deepseek (explicit env select)
#   > ~/.vector/config.yaml  provider: deepseek + deepseek_api_key
#   > Vector / Claude OAuth tokens
#   > ANTHROPIC_API_KEY
#   > OPENROUTER_API_KEY  (multi-model fallback)
#
# Force a specific provider even when another key is also present:
#   VECTOR_PROVIDER=openrouter   (or anthropic)

# --- DeepSeek (CLI default when this key is set) ---
DEEPSEEK_API_KEY=
# Optional overrides — both default to the values shown:
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- OpenRouter (multi-model fallback) ---
OPENROUTER_API_KEY=
# Force OpenRouter even when a DeepSeek key is present:
# VECTOR_PROVIDER=openrouter
# Pick a specific model (defaults to claude-sonnet-4-6, prefixed anthropic/ if no slash):
# VECTOR_MODEL=anthropic/claude-3-5-sonnet

# --- Anthropic direct (optional) ---
# ANTHROPIC_API_KEY=

# --- Qwen / DashScope (the routing brain) ---
QWEN_API_KEY=
# QWEN_MODEL=qwen-max

# --- Perception VLM (describe_scene / find_objects / the `look` skill — resolves ordinal/positional NL) ---
# Defaults to OpenRouter (google/gemma-4-31b-it via OPENROUTER_API_KEY). When OpenRouter is in
# arrears (402), route to a LOCAL Ollama VLM — plug-and-play, no credit (unblocked ordinal
# grounding R192/E28). gemma4:e4b resolves left-right ordinals; must be pulled in Ollama first.
# VECTOR_VLM_URL=http://localhost:11434/v1
# VECTOR_VLM_MODEL=gemma4:e4b

# --- Vision judge (eyes — second witness; judge model family MUST differ from the routing brain) ---
VECTOR_JUDGE_BASE_URL=
VECTOR_JUDGE_MODEL=
VECTOR_JUDGE_API_KEY=

# --- Simulation ---
# MUJOCO_GL=egl            # headless GL backend for frame capture
# VECTOR_SIM_WITH_ARM=1    # attach the arm to the sim robot
# VECTOR_NO_ROS2=1         # run the sim path without a ROS2 install

# --- Loop (self-evolving round supervisor) ---
# AGENT_ADAPTER=loop/harness/claude.sh   # which agent harness drives a round
# ROUND_TIMEOUT=3600                     # seconds per round
# ROUND_MEM_GB=40                        # per-round memory cap (systemd scope)
# INTERVAL=60                            # seconds between round ticks
