#!/usr/bin/env bash
# Thin alias: equivalent to `vector-cli --sim`.
#
# `vector-cli --sim` now auto-detects macOS and re-execs under mjpython so
# a viewer window opens by default. This script is kept for backward
# compatibility and convenience.
#
# Use --headless to suppress the viewer window:
#   vector-cli --sim --headless
#
# Pass any extra vector-cli flags after `--sim`:
#   vector-sim --model anthropic/claude-haiku-4-5
set -euo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# uv-managed .venv preferred; legacy .venv-nano fallback
venv_python="$here/.venv/bin/python"
[[ -x "$venv_python" ]] || venv_python="$here/.venv-nano/bin/python"

if [[ ! -x "$venv_python" ]]; then
  echo "error: venv not found at $here/.venv — run 'uv venv && uv pip install -e .' first." >&2
  exit 1
fi

exec "$venv_python" -m vector_os_nano.vcli.cli --sim "$@"
